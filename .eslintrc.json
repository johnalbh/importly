{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "rules": {
    "eqeqeq": "warn",
    "no-throw-literal": "warn",
    "@typescript-eslint/semi": ["warn"]
  },
  "ignorePatterns": ["out", "**/*.d.ts"]
}
